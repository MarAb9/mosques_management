# =============================================================================
# Mosques Management — Local Docker Environment
# =============================================================================
# These are LOCAL DEVELOPMENT defaults for docker compose.
# Copy this file to .env and adjust values as needed.
#
# WARNING: Do NOT use these values in production.
# WARNING: Do NOT commit your .env file to Git.
# =============================================================================

APP_PORT=8080
APP_ENV=development
APP_URL=http://localhost:8080
APP_TIMEZONE=Africa/Casablanca
TRUST_PROXY_HEADERS=false
SESSION_IDLE_TIMEOUT=1800
SESSION_ABSOLUTE_TIMEOUT=28800
SESSION_REGENERATE_INTERVAL=900
LOGIN_MAX_ATTEMPTS=5
LOGIN_DECAY_SECONDS=900
PHPMYADMIN_PORT=8081
DB_PORT_FORWARD=3307
DB_NAME=mosques_management
DB_USER=mosques
DB_PASS=mosques_password
DB_ROOT_PASS=mosques_root_password

# Maps
MAP_PROVIDER=maplibre
MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
MAP_DEFAULT_LATITUDE=34.6814
MAP_DEFAULT_LONGITUDE=-1.9086
MAP_DEFAULT_ZOOM=9

# Public mosque API
API_ACCESS_MODE=key
API_ALLOWED_ORIGINS=https://other-website.example
API_RATE_LIMIT=120
API_RATE_WINDOW=60
API_KEY_HASH=

