{
  "name": "mosques-management-ui",
  "private": true,
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss -i ./resources/css/app.css -o ./public/assets/dist/app.min.css --minify",
    "build:js": "esbuild ./resources/js/app.js ./resources/js/pages/login.js ./resources/js/pages/dashboard.js ./resources/js/pages/quran.js ./resources/js/pages/maps.js ./resources/js/pages/import-export.js ./resources/js/components/backup-confirm.js --bundle --minify --format=iife --target=es2020 --outdir=./public/assets/dist --entry-names=[name].min",
    "watch:css": "tailwindcss -i ./resources/css/app.css -o ./public/assets/dist/app.min.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.3.2",
    "esbuild": "^0.25.0",
    "tailwindcss": "4.3.2"
  },
  "dependencies": {
    "@googlemaps/markerclusterer": "^2.6.2"
  }
}
