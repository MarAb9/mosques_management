# =============================================================================
# Mosques Management — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Environment and secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# Real config (use includes/config.example.php as template)
includes/config.php
includes/config.local.php

# ---------------------------------------------------------------------------
# Composer dependencies (install via: composer install)
# ---------------------------------------------------------------------------
vendor/

# ---------------------------------------------------------------------------
# Database dumps and backups
# ---------------------------------------------------------------------------
*.sql
!database/migrations/*.sql
backups/
*.zip
*.rar
*.7z
*.gz
*.tar
*.bak

# ---------------------------------------------------------------------------
# Uploaded content (user-generated, not part of source)
# ---------------------------------------------------------------------------
uploads/mosques/*
!uploads/mosques/.gitkeep

# ---------------------------------------------------------------------------
# Logs, cache, temp files
# ---------------------------------------------------------------------------
logs/
*.log
cache/
tmp/

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Icon?

# ---------------------------------------------------------------------------
# IDE and editor files
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
nbproject/
.project
.settings/

# ---------------------------------------------------------------------------
# Node (not currently used, but protect future installs)
# ---------------------------------------------------------------------------
node_modules/
