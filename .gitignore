# =============================================================================
# Mosques Management — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Environment and secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# Legacy local config files may still contain real credentials.
includes/config.php
includes/config.local.php
# Current private database override (copy config/database.local.php.example).
config/*.local.php

# ---------------------------------------------------------------------------
# Composer dependencies (install via: composer install)
# ---------------------------------------------------------------------------
vendor/

# ---------------------------------------------------------------------------
# Database dumps and backups
# ---------------------------------------------------------------------------
*.sql
!database/migrations/*.sql
backups/
*.zip
*.rar
*.7z
*.gz
*.tar
*.bak

# ---------------------------------------------------------------------------
# Uploaded content (user-generated, not part of source)
# ---------------------------------------------------------------------------
public/uploads/mosques/*
!public/uploads/mosques/.gitkeep

# ---------------------------------------------------------------------------
# Logs, cache, temp files
# ---------------------------------------------------------------------------
/logs/
*.log
/cache/
tmp/
storage/logs/*
!storage/logs/.gitkeep
storage/cache/*
!storage/cache/.gitkeep
/clean.xlsx

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Icon?

# ---------------------------------------------------------------------------
# IDE and editor files
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
nbproject/
.project
.settings/

# ---------------------------------------------------------------------------
# Node (not currently used, but protect future installs)
# ---------------------------------------------------------------------------
node_modules/
